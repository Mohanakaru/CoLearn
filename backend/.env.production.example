# ═══════════════════════════════════════════════════════════════════
#  CoLearn – PRODUCTION Environment Variables
#  Copy this to backend/.env on your production server.
#  Never commit this file with real values to version control.
# ═══════════════════════════════════════════════════════════════════

PORT=3000
NODE_ENV=production

# ───────────────────────────────────────────────────────────────────
# Your production domain (no trailing slash)
# GOOGLE_REDIRECT_URI is auto-derived as: APP_URL/api/drive/callback
# ───────────────────────────────────────────────────────────────────
APP_URL=https://yourdomain.com

# ───────────────────────────────────────────────────────────────────
# CORS – restrict to your production domain(s)
# Comma-separated list or * (not recommended for production)
# ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com

# ───────────────────────────────────────────────────────────────────
# Gmail SMTP – outbound email (invites, OTP)
# ───────────────────────────────────────────────────────────────────
SMTP_USER=your-smtp-gmail@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM_NAME=CoLearn

# ───────────────────────────────────────────────────────────────────
# Firebase – Service Account
# Download from Firebase Console → Project Settings → Service Accounts
# ───────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_KEY_PATH=./config/serviceAccountKey.json
FIREBASE_API_KEY=your-firebase-web-api-key

# ───────────────────────────────────────────────────────────────────
# Google OAuth2 – Google Drive Integration
#
# ARCHITECTURE: This is ONE set of credentials for the entire CoLearn
# application. Every registered user independently authorizes THEIR
# own Google Drive through this single OAuth client. You do NOT create
# credentials per user. This is the same architecture as Notion, Slack,
# Canva, Google Classroom, etc.
#
# ONE-TIME ADMIN SETUP:
#   1. https://console.cloud.google.com/
#   2. APIs & Services → Library → Enable "Google Drive API"
#   3. APIs & Services → OAuth consent screen:
#        - App name: CoLearn
#        - User type: External
#        - Scopes: https://www.googleapis.com/auth/drive.file
#        - Publish status: "In production" (for all users)
#          OR keep "Testing" and add test user emails
#   4. APIs & Services → Credentials → Create OAuth 2.0 Client ID
#        - Application type: Web application
#        - Authorized redirect URIs (add BOTH for flexibility):
#            https://yourdomain.com/api/drive/callback
#            http://localhost:3000/api/drive/callback
#   5. Paste Client ID and Secret below
# ───────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=123456789-abcdefghijklmnop.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the auto-derived redirect URI
# GOOGLE_REDIRECT_URI=https://yourdomain.com/api/drive/callback
