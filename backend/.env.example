# ─────────────────────────────────────────────────────────────────
#  CoLearn – Backend Environment Configuration
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Your machine's LAN IPv4 address.
# Find it with:  ipconfig   (Windows) → look under your Wi-Fi adapter
#                ifconfig   (Mac/Linux) → en0 or wlan0
# Example: HOST_IP=192.168.1.100
HOST_IP=YOUR_LOCAL_IP_HERE

# ── CORS ──────────────────────────────────────────────────────────
# '*'  → allow all origins (safe for LAN development)
# For production replace with your actual domain, e.g.:
#   ALLOWED_ORIGINS=https://CoLearn.yourdomain.com
ALLOWED_ORIGINS=*

# ── Gmail SMTP (for OTP email delivery) ──────────────────────────
# 1. Enable 2-Factor Authentication on your Google account
# 2. Visit: https://myaccount.google.com/apppasswords
# 3. Generate an App Password for "Mail"
# 4. Paste it below (no spaces)
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM_NAME=CoLearn

# ── Firebase Configuration ────────────────────────────────────────
# Firebase Project ID (Firebase Console → Project Settings → General)
FIREBASE_PROJECT_ID=your-project-id

# Path to your Firebase Admin SDK service account JSON key
# Download from: Firebase Console → Project Settings → Service Accounts
# → Generate new private key → place the JSON here:
FIREBASE_KEY_PATH=./config/serviceAccountKey.json

# Firebase Web API Key
# Firebase Console → Project Settings → General → Web API Key
FIREBASE_API_KEY=your_firebase_web_api_key

# ─────────────────────────────────────────────────────────────────
#  LAN SETUP GUIDE
# ─────────────────────────────────────────────────────────────────
#
#  To access CoLearn from another device on the same Wi-Fi:
#
#  STEP 1 – Find your host machine's IP:
#    Windows:   Run ipconfig in Command Prompt
#               Look for: Wireless LAN adapter Wi-Fi → IPv4 Address
#    Mac/Linux: Run ifconfig or ip addr
#
#  STEP 2 – Set HOST_IP above to that address (e.g. 192.168.1.100)
#
#  STEP 3 – Start the server:
#    cd backend && npm run dev
#
#  STEP 4 – On ANY device on the same Wi-Fi, open:
#    http://<HOST_IP>:3000
#
#  NOTES:
#  • The frontend config.js auto-detects the server IP from the URL.
#    No extra config needed on other devices.
#  • Firebase Auth and Firestore are cloud services — they work from
#    any device with internet access regardless of local IP.
#  • Make sure Windows Firewall allows inbound connections on port 3000.
# ─────────────────────────────────────────────────────────────────
#    (Windows will usually prompt you the first time you run the server)
# ─────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────
#  Google OAuth2 – Google Drive Integration
# ─────────────────────────────────────────────────────────────────
#  STEP 1 – Go to: https://console.cloud.google.com/
#  STEP 2 – Create or select a project
#  STEP 3 – Enable "Google Drive API" in APIs & Services → Library
#  STEP 4 – Credentials → + Create → OAuth 2.0 Client ID (Web app)
#  STEP 5 – Add Authorized Redirect URI:
#              http://localhost:3000/api/drive/callback   (local dev)
#              https://yourdomain.com/api/drive/callback  (production)
#  STEP 6 – Paste Client ID and Secret below
#
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/drive/callback
